{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "trailingComma": "all",
  "singleQuote": true,
  "semi": true,
  "tabWidth": 2,
  "useTabs": false,
  "sortPackageJson": true,
  "overrides": [
    {
      "files": ["**/*.md", "**/*.yaml", "**/*.yml"],
      "options": {
        "singleQuote": false
      }
    }
  ],
  "ignorePatterns": ["**/node_modules/**", "**/dist/**", "**/build/**", "**/charts/**"]
}

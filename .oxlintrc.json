{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "typeAware": true
  },
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "pedantic": "off",
    "perf": "warn",
    "style": "off",
    "restriction": "warn"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "no-empty-function": "off",
        "no-magic-numbers": "off",
        "no-non-null-assertion": "off",
        "no-unsafe-type-assertion": "off"
      }
    }
  ],
  "ignorePatterns": ["**/node_modules/**", "**/dist/**", "**/build/**", "**/.git/**", "test-app/**"]
}

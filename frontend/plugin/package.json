    "@formio/angular": "7.0.0",
    "@valtimo/components": ">=13.21.0 <14",
    "@valtimo/plugin": ">=13.21.0 <14",
    "@valtimo/process-link": ">=13.21.0 <14",
    "@valtimo/security": ">=13.21.0 <14",
    "@valtimo/shared": ">=13.21.0 <14",
    "carbon-components-angular": "5.57.6",

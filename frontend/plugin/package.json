    "@formio/angular": "7.0.0",
    "@types/jest": "^30.0.0",
    "@valtimo/components": "13.38.0",
    "@valtimo/plugin": "13.38.0",
    "@valtimo/process-link": "13.38.0",
    "@valtimo/security": "13.38.0",
    "@valtimo/shared": "13.38.0",
    "carbon-components-angular": "5.57.6",
    "formiojs": "4.19.5",
    "jest": "^30.3.0",
    "ng-packagr": "^19.0.0",
    "ts-jest": "^29.4.9"
  },

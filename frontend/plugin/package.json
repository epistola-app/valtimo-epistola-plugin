    "@valtimo/process-link": "13.21.0",
    "@valtimo/shared": "13.21.0",
    "jest": "^30.3.0",
    "ng-packagr": "^19.0.0",
    "ts-jest": "^29.4.9"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "@angular/forms": ">=17.0.0",
    "@angular/router": ">=17.0.0",
    "@valtimo/components": "^13.21.0",
    "@valtimo/plugin": "^13.21.0",

      "secret": "epistola-dev-secret",
      "serviceAccountsEnabled": true,
      "redirectUris": ["http://localhost:4010/*"],
      "webOrigins": ["http://localhost:4010"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:4010/*"
      },
      "defaultClientScopes": ["web-origins", "profile", "roles", "email", "openid"],
      "protocolMappers": [
        {
          "name": "group-membership-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": ["role_list", "profile", "email", "roles", "web-origins"]

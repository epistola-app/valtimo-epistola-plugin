{
    "display": "form",
    "components": [
        {
            "key": "applicant",
            "type": "fieldset",
            "label": "Aanvrager",
            "components": [
                {
                    "key": "applicant.firstName",
                    "type": "textfield",
                    "input": true,
                    "label": "Voornaam",
                    "defaultValue": "Jan",
                    "validate": { "required": true }
                },
                {
                    "key": "applicant.lastName",
                    "type": "textfield",
                    "input": true,
                    "label": "Achternaam",
                    "defaultValue": "de Vries",
                    "validate": { "required": true }
                },
                {
                    "key": "applicant.bsn",
                    "type": "textfield",
                    "input": true,
                    "label": "BSN (leeg laten om fout te simuleren)",
                    "defaultValue": "",
                    "validate": { "required": false, "pattern": "^([0-9]{9})?$" }
                },
                {
                    "key": "applicant.address.street",
                    "type": "textfield",
                    "input": true,
                    "label": "Straat",
                    "defaultValue": "Keizersgracht",
                    "validate": { "required": true }
                },
                {
                    "key": "applicant.address.houseNumber",
                    "type": "textfield",
                    "input": true,
                    "label": "Huisnummer",
                    "defaultValue": "42",
                    "validate": { "required": true }
                },
                {
                    "key": "applicant.address.postalCode",
                    "type": "textfield",
                    "input": true,
                    "label": "Postcode",
                    "defaultValue": "1015AB",
                    "validate": { "required": true, "pattern": "^[0-9]{4}[A-Z]{2}$" }
                },
                {
                    "key": "applicant.address.city",
                    "type": "textfield",
                    "input": true,
                    "label": "Woonplaats",
                    "defaultValue": "Amsterdam",
                    "validate": { "required": true }
                }
            ]
        },
        {
            "key": "property",
            "type": "fieldset",
            "label": "Locatie",
            "components": [
                {
                    "key": "property.address.street",
                    "type": "textfield",
                    "input": true,
                    "label": "Straat",
                    "defaultValue": "Herengracht",
                    "validate": { "required": true }
                },
                {
                    "key": "property.address.houseNumber",
                    "type": "textfield",
                    "input": true,
                    "label": "Huisnummer",
                    "defaultValue": "100",
                    "validate": { "required": true }
                },
                {
                    "key": "property.address.postalCode",
                    "type": "textfield",
                    "input": true,
                    "label": "Postcode",
                    "defaultValue": "1015BS",
                    "validate": { "required": true, "pattern": "^[0-9]{4}[A-Z]{2}$" }
                },
                {
                    "key": "property.address.city",
                    "type": "textfield",
                    "input": true,
                    "label": "Woonplaats",
                    "defaultValue": "Amsterdam",
                    "validate": { "required": true }
                },
                {
                    "key": "property.kadastraalNummer",
                    "type": "textfield",
                    "input": true,
                    "label": "Kadastraal nummer",
                    "defaultValue": "ASD01-A-1234"
                }
            ]
        },
        {
            "key": "activities",
            "type": "datagrid",
            "input": true,
            "label": "Activiteiten",
            "reorder": true,
            "defaultValue": [
                {
                    "type": "Verbouwing",
                    "description": "Aanbouw aan achterzijde woning",
                    "estimatedCost": 45000
                }
            ],
            "components": [
                {
                    "key": "type",
                    "type": "textfield",
                    "input": true,
                    "label": "Type activiteit",
                    "validate": { "required": true }
                },
                {
                    "key": "description",
                    "type": "textarea",
                    "input": true,
                    "label": "Beschrijving",
                    "validate": { "required": true }
                },
                {
                    "key": "estimatedCost",
                    "type": "number",
                    "input": true,
                    "label": "Geschatte kosten (€)"
                }
            ]
        },
        {
            "key": "submit",
            "type": "button",
            "input": true,
            "label": "Indienen",
            "action": "submit",
            "theme": "primary",
            "disableOnInvalid": true
        }
    ]
}

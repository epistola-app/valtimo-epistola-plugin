{
  "display": "form",
  "components": [
    {
      "type": "hidden",
      "key": "epistolaTaskInstanceId",
      "input": true,
      "label": "Epistola Task Id",
      "persistent": false,
      "properties": {
        "sourceKey": "epistola-task:id"
      }
    },
    {
      "key": "pv:decision",
      "type": "select",
      "input": true,
      "label": "Beslissing",
      "defaultValue": "gegrond",
      "data": {
        "values": [
          { "label": "Gegrond", "value": "gegrond" },
          { "label": "Ongegrond", "value": "ongegrond" },
          { "label": "Deels gegrond", "value": "deels_gegrond" }
        ]
      },
      "validate": { "required": true }
    },
    {
      "key": "pv:motivation",
      "type": "textarea",
      "input": true,
      "label": "Motivatie",
      "rows": 5,
      "defaultValue": "Na heroverweging is gebleken dat de dakkapel voldoet aan de geldende welstandscriteria. Het bezwaar wordt gegrond verklaard.",
      "validate": { "required": true }
    },
    {
      "type": "epistola-document-preview",
      "key": "preview",
      "input": false,
      "label": "Voorbeeld Besluitbrief",
      "processDefinitionKey": "objection-handling",
      "sourceActivityId": "generate-decision",
      "overrideMapping": {
        "pv": {
          "motivation": "form:pv:motivation",
          "decision": "form:pv:decision"
        }
      }
    },
    {
      "key": "submit",
      "type": "button",
      "input": true,
      "label": "Bevestigen",
      "action": "submit",
      "theme": "primary",
      "disableOnInvalid": true
    }
  ]
}

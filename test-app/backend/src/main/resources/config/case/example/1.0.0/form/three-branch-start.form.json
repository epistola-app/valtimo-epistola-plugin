{
  "display": "form",
  "components": [
    {
      "key": "pv:branch",
      "type": "radio",
      "input": true,
      "label": "Tak",
      "tableView": true,
      "defaultValue": "a",
      "values": [
        { "label": "A (gekoppeld / generate-document)", "value": "a" },
        { "label": "B (geen koppeling)", "value": "b" },
        { "label": "C (geen koppeling)", "value": "c" }
      ],
      "validate": {
        "required": true
      }
    },
    {
      "key": "pv:companyName",
      "type": "textfield",
      "input": true,
      "label": "Company Name",
      "tableView": true,
      "defaultValue": "Acme B.V.",
      "validate": {
        "required": true
      }
    },
    {
      "key": "submit",
      "type": "button",
      "input": true,
      "label": "Submit",
      "tableView": false,
      "disableOnInvalid": true,
      "action": "submit",
      "theme": "primary"
    }
  ]
}

<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_recv_task" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.23.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.21.0">
  <bpmn:message id="Message_EpistolaDocumentGenerated" name="EpistolaDocumentGenerated" />
  <bpmn:process id="single-document-receive-task" name="Generate Single Document (receive task + timer)" isExecutable="true">
    <bpmn:documentation>Example that waits for the EpistolaDocumentGenerated completion message using a receive task instead of a round intermediate catch event, with an interrupting 2-minute boundary timer. A receive task is NOT auto-wired by the plugin, so the epistolaWaitFor correlation token must be set explicitly via a camunda:inputParameter.</bpmn:documentation>
    <bpmn:startEvent id="startEvent">
      <bpmn:outgoing>Flow_start_gen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_start_gen" sourceRef="startEvent" targetRef="generate-document" />
    <bpmn:serviceTask id="generate-document" name="Generate document" camunda:expression="${null}">
      <bpmn:incoming>Flow_start_gen</bpmn:incoming>
      <bpmn:outgoing>Flow_gen_recv</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="boundary-generate-error" name="EpistolaGenerationError" attachedToRef="generate-document">
      <bpmn:outgoing>Flow_boundary_err</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_gen" errorRef="Error_EpistolaDocumentError" camunda:errorCodeVariable="errorCode" camunda:errorMessageVariable="errorMessage" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_boundary_err" sourceRef="boundary-generate-error" targetRef="end-error" />
    <bpmn:endEvent id="end-error">
      <bpmn:incoming>Flow_boundary_err</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_gen_recv" sourceRef="generate-document" targetRef="wait-for-generation" />
    <bpmn:receiveTask id="wait-for-generation" name="Wait for generation" messageRef="Message_EpistolaDocumentGenerated">
      <!-- Receive tasks are NOT auto-wired by the plugin (auto-wiring only attaches to round
           intermediate message catch events), so the epistolaWaitFor correlation token MUST be
           pinned explicitly here. It is the jobPath of the generate-document result variable. -->
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="epistolaWaitFor">${epistolaResult.jobPath}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_gen_recv</bpmn:incoming>
      <bpmn:outgoing>Flow_recv_end</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:boundaryEvent id="boundary-timeout" name="30 minutes elapsed" cancelActivity="true" attachedToRef="wait-for-generation">
      <bpmn:outgoing>Flow_timeout_end</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1">
        <bpmn:timeDuration>PT30M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_timeout_end" sourceRef="boundary-timeout" targetRef="end-timeout" />
    <bpmn:endEvent id="end-timeout" name="Generation timed out">
      <bpmn:incoming>Flow_timeout_end</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_timeout" errorRef="Error_EpistolaGenerationTimeout" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_recv_end" sourceRef="wait-for-generation" targetRef="end-success" />
    <bpmn:endEvent id="end-success">
      <bpmn:incoming>Flow_recv_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:textAnnotation id="TextAnnotation_0e3bvwm">
      <bpmn:text>Deze taak vereist een Valtimo process koppeling</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0gngtw5" associationDirection="None" sourceRef="generate-document" targetRef="TextAnnotation_0e3bvwm" />
  </bpmn:process>
  <bpmn:error id="Error_EpistolaDocumentError" name="EpistolaDocumentError" />
  <bpmn:error id="Error_EpistolaGenerationTimeout" name="EpistolaGenerationTimeout" errorCode="EpistolaGenerationTimeout" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="single-document-receive-task">
      <bpmndi:BPMNShape id="_BPMNShape_StartEvent_2" bpmnElement="startEvent">
        <dc:Bounds x="152" y="99" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="generate-document_di" bpmnElement="generate-document">
        <dc:Bounds x="240" y="77" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="boundary-generate-error_di" bpmnElement="boundary-generate-error">
        <dc:Bounds x="272" y="139" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="246" y="182" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end-error_di" bpmnElement="end-error">
        <dc:Bounds x="222" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="wait-for-generation_di" bpmnElement="wait-for-generation">
        <dc:Bounds x="410" y="77" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="boundary-timeout_di" bpmnElement="boundary-timeout">
        <dc:Bounds x="442" y="139" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="421" y="182" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end-timeout_di" bpmnElement="end-timeout">
        <dc:Bounds x="442" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="420" y="325" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end-success_di" bpmnElement="end-success">
        <dc:Bounds x="592" y="99" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TextAnnotation_0e3bvwm_di" bpmnElement="TextAnnotation_0e3bvwm">
        <dc:Bounds x="150" y="200" width="100" height="55" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_gen_di" bpmnElement="Flow_start_gen">
        <di:waypoint x="188" y="117" />
        <di:waypoint x="240" y="117" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_gen_recv_di" bpmnElement="Flow_gen_recv">
        <di:waypoint x="340" y="117" />
        <di:waypoint x="410" y="117" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_recv_end_di" bpmnElement="Flow_recv_end">
        <di:waypoint x="510" y="117" />
        <di:waypoint x="592" y="117" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_timeout_end_di" bpmnElement="Flow_timeout_end">
        <di:waypoint x="460" y="175" />
        <di:waypoint x="460" y="282" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_boundary_err_di" bpmnElement="Flow_boundary_err">
        <di:waypoint x="290" y="175" />
        <di:waypoint x="290" y="282" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Association_0gngtw5_di" bpmnElement="Association_0gngtw5">
        <di:waypoint x="256" y="157" />
        <di:waypoint x="220" y="200" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>

{
  "display": "form",
  "components": [
    {
      "key": "pv:letterType",
      "type": "radio",
      "input": true,
      "label": "Brief type",
      "tableView": true,
      "defaultValue": "a",
      "values": [
        { "label": "Type A", "value": "a" },
        { "label": "Type B", "value": "b" }
      ],
      "validate": {
        "required": true
      }
    },
    {
      "key": "pv:companyName",
      "type": "textfield",
      "input": true,
      "label": "Company Name",
      "tableView": true,
      "defaultValue": "Acme B.V.",
      "validate": {
        "required": true
      }
    },
    {
      "key": "submit",
      "type": "button",
      "input": true,
      "label": "Submit",
      "tableView": false,
      "disableOnInvalid": true,
      "action": "submit",
      "theme": "primary"
    }
  ]
}

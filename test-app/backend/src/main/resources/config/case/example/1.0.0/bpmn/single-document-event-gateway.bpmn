        <di:waypoint x="652" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_boundary_err_di" bpmnElement="Flow_boundary_err">
        <di:waypoint x="290" y="175" />
        <di:waypoint x="290" y="282" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Association_0gngtw5_di" bpmnElement="Association_0gngtw5">
        <di:waypoint x="256" y="157" />

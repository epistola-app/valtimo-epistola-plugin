      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_msg_end_di" bpmnElement="Flow_msg_end">
        <di:waypoint x="568" y="117" />
        <di:waypoint x="652" y="117" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_gw_timer_di" bpmnElement="Flow_gw_timer">
        <di:waypoint x="430" y="142" />
        <di:waypoint x="430" y="240" />
        <di:waypoint x="532" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_timer_end_di" bpmnElement="Flow_timer_end">
